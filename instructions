📌 7. Library Management System (Android - Java + SQLite)

Aim

To store book details using SQLite database.

XML Layout

<LinearLayout
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <EditText
        android:id="@+id/editTextBookName"
        android:hint="Book Name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/editTextAuthor"
        android:hint="Author"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <Button
        android:text="Save"
        android:onClick="sav"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</LinearLayout>

MainActivity.java

public void sav(View v) {
    String name = editTextBookName.getText().toString();
    String author = editTextAuthor.getText().toString();

    db.save(name, author);
    Toast.makeText(this, "Saved", Toast.LENGTH_SHORT).show();
}

DB.java

public class DB extends SQLiteOpenHelper {

    public DB(Context context) {
        super(context, "LibraryDB", null, 1);
    }

    public void onCreate(SQLiteDatabase db) {
        db.execSQL("CREATE TABLE books (id INTEGER PRIMARY KEY AUTOINCREMENT, name TEXT, author TEXT)");
    }

    public void onUpgrade(SQLiteDatabase db, int oldVersion, int newVersion) {
        db.execSQL("DROP TABLE IF EXISTS books");
        onCreate(db);
    }

    public void save(String name, String author) {
        SQLiteDatabase db = this.getWritableDatabase();
        ContentValues cv = new ContentValues();
        cv.put("name", name);
        cv.put("author", author);
        db.insert("books", null, cv);
    }
}
